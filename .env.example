# Stripe — copy this file to .env.local and fill in your keys.
# Get your keys from https://dashboard.stripe.com/apikeys (use test keys for dev).

# Server-side secret key. NEVER expose this to the client.
STRIPE_SECRET_KEY=sk_test_...

# Public base URL used to build Stripe success/cancel redirect URLs.
# Optional in dev — falls back to the incoming request origin if unset.
# Set this in production, e.g. https://delightandco.com.au
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resend — copy this file to .env.local and fill in your key.
# Get your key from https://resend.com/api-keys
RESEND_API_KEY=re_...

# Email address that receives new-order notifications.
OWNER_EMAIL=owner@example.com
